{
  "name": "backend-base",
  "description": "description here!!!",
  "version": "1.0.0",
  "main": "dist/index.js",
  "engines": {
    "node": ">=6.14.4",
    "npm": ">=3.10.10"
  },
  "keywords": [
    "typescript",
    "node"
  ],
  "contributors": [
    {
      "name": "Hugo Virgen",
      "email": "virgenherrera@gmail.com"
    }
  ],
  "homepage": "https://github.com/username/repository#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/username/repository"
  },
  "bugs": {
    "url": "https://github.com/username/repository/issues"
  },
  "scripts": {
    "start": "node ./dist/index.js",
    "dev": "./node_modules/.bin/nodemon ./src/index.ts",
    "test": "npm run tslint && nyc mocha",
    "prestart": "npm run build",
    "build": "npm run cleanup && npm run test && npm run tsc",
    "cleanup": "rimraf .nyc_output dist coverage",
    "tslint": "./node_modules/.bin/tslint -c ./tslint.json -p ./tsconfig.json",
    "tsc": "./node_modules/.bin/tsc",
    "tsc:watch": "./node_modules/.bin/tsc -w --sourceMap"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/chai": "^4.1.5",
    "@types/mocha": "^5.2.5",
    "@types/node": "^10.5.8",
    "@types/rimraf": "^2.0.2",
    "@types/supertest": "^2.0.6",
    "@types/winston": "^2.4.4",
    "chai": "^4.1.2",
    "mocha": "^5.2.0",
    "nodemon": "^1.18.9",
    "nyc": "^13.0.1",
    "rimraf": "^2.6.2",
    "source-map-support": "^0.5.9",
    "supertest": "^3.3.0",
    "ts-node": "^7.0.0",
    "tslint": "^5.11.0",
    "typescript": "^3.0.3"
  },
  "nyc": {
    "extension": [
      ".ts",
      ".tsx"
    ],
    "exclude": [
      "**/*.d.ts",
      "test/**",
      "coverage/**",
      "dist/**"
    ],
    "reporter": [
      "cobertura",
      "html",
      "text-summary"
    ],
    "all": true
  },
  "nodemonConfig": {
    "nodeArgs": [
      "--inspect-brk"
    ],
    "watch": [
      "config/",
      "src/"
    ],
    "ext": "ts,json",
    "ignore": [
      ".git",
      "node_modules/**/node_modules"
    ],
    "execMap": {
      "ts": "ts-node"
    }
  }
}
